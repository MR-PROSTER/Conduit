{
  "name": "@conduit/collaboration-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./FileManager": {
      "types": "./dist/FileManager.d.ts",
      "default": "./dist/FileManager.js"
    },
    "./CursorManager": {
      "types": "./dist/CursorManager.d.ts",
      "default": "./dist/CursorManager.js"
    },
    "./DraftManager": {
      "types": "./dist/DraftManager.d.ts",
      "default": "./dist/DraftManager.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@conduit/shared-types": "workspace:*",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.1"
  }
}
