{
  "name": "@conduit/extension",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "publisher": "conduit",
  "main": "./dist/extension.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@conduit/ai-core": "workspace:*",
    "@conduit/collaboration-core": "workspace:*",
    "@conduit/git-core": "workspace:*",
    "@conduit/shared-types": "workspace:*",
    "diff": "*",
    "lib0": "*",
    "ws": "*",
    "y-protocols": "*",
    "y-websocket": "*",
    "yjs": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:conduit.signIn",
    "onCommand:conduit.signOut",
    "onCommand:conduit.showAccount",
    "onCommand:conduit.createSession",
    "onCommand:conduit.joinSession",
    "onCommand:conduit.leaveSession",
    "onCommand:conduit.restoreDrafts",
    "onCommand:conduit.switchBranch",
    "onView:conduit.sidebar",
    "onView:conduit.aiPanel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "conduit.signIn",
        "title": "conduit: Sign In"
      },
      {
        "command": "conduit.signOut",
        "title": "conduit: Sign Out"
      },
      {
        "command": "conduit.showAccount",
        "title": "conduit: Show Account"
      },
      {
        "command": "conduit.createSession",
        "title": "conduit: Create Session"
      },
      {
        "command": "conduit.joinSession",
        "title": "conduit: Join Session"
      },
      {
        "command": "conduit.leaveSession",
        "title": "conduit: Leave Session"
      },
      {
        "command": "conduit.restoreDrafts",
        "title": "conduit: Restore Drafts"
      },
      {
        "command": "conduit.switchBranch",
        "title": "conduit: Switch Branch"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conduit",
          "title": "conduit",
          "icon": "media/conduit.svg"
        }
      ]
    },
    "views": {
      "conduit": [
        {
          "type": "webview",
          "id": "conduit.sidebar",
          "name": "Collaborators & Sessions"
        },
        {
          "type": "webview",
          "id": "conduit.aiPanel",
          "name": "AI Assistant"
        }
      ]
    },
    "configuration": {
      "title": "conduit",
      "properties": {
        "conduit.websocketUrl": {
          "type": "string",
          "default": "ws://localhost:4000/ws",
          "description": "WebSocket URL for conduit backend"
        },
        "conduit.backendUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "HTTP URL for conduit backend"
        }
      }
    }
  }
}
